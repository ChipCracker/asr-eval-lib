;; asr-eval-lib German ORT numbers component GLM
* name "asr-eval-lib-de-orthographic-numbers.glm"
* desc "Starter rules for German ORT number normalization"
* format = 'NIST2'
* copy_no_hit = 'T'
* case_sensitive = 'F'
;;
;; Rules operate after Python text normalization. For example, ß is already ss.
